---
import type { SidebarNavGroup } from "../lib/catalog";

type Props = {
  activeHref?: string;
  groups: SidebarNavGroup[];
};

const { activeHref = "", groups } = Astro.props;
---

<aside class="sidebar-panel">
  <div class="sidebar-heading">Documentation</div>
  {groups.map((group) => (
    <section class="sidebar-group">
      <h3>{group.label}</h3>
      <ul>
        {group.items.map((item) => (
          <li>
            <a class:list={[item.href === activeHref && "is-active"]} href={item.href}>
              <span>{item.label}</span>
              {item.meta ? <small>{item.meta}</small> : null}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</aside>
