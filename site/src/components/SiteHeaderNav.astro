---
import { getHosts } from "../lib/catalog";

type Props = {
  currentHost?: string;
};

const { currentHost } = Astro.props;
const hosts = await getHosts();
---

<nav class="top-nav">
  {hosts.map(({ count, host, meta }) => (
    <a class:list={["top-nav-link", currentHost === host && "is-active"]} href={`/${host}/`}>
      <span>{meta.label}</span>
      <small>{count}</small>
    </a>
  ))}
</nav>
