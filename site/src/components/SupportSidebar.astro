---
import type { DocumentRecord } from "../lib/catalog";

type Group = {
  items: DocumentRecord[];
  label: string;
};

type Props = {
  activeHref?: string;
  groups: Group[];
};

const { activeHref = "", groups } = Astro.props;
---

<aside class="sidebar-panel">
  <div class="sidebar-heading">Support Topics</div>
  {groups.map((group) => (
    <section class="sidebar-group">
      <h3>{group.label}</h3>
      <ul>
        {group.items.map((item) => (
          <li>
            <a class:list={[item.href === activeHref && "is-active"]} href={item.href}>
              {item.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</aside>
