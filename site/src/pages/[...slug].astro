---
import BilingualBlock from "../components/BilingualBlock.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import DirectoryList from "../components/DirectoryList.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import HostSectionNav from "../components/HostSectionNav.astro";
import LanguageToggle from "../components/LanguageToggle.astro";
import SectionList from "../components/SectionList.astro";
import SupportSidebar from "../components/SupportSidebar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getArchivePaths,
  getArchiveRecord,
  getBreadcrumbsFromSlug,
  getDocsNavigation,
  getRelatedDocuments,
  getSiteMeta,
  getSupportTopicGroups,
  prettifySegment,
  type ArchiveRecord,
  type DocumentRecord,
} from "../lib/catalog";
import { listDocumentPaths, readMirrorDocument, resolveDocumentPath, sourcePathToSlug } from "../lib/content";

type RouteProps = {
  kind: "archive" | "document";
};

export async function getStaticPaths() {
  const files = await listDocumentPaths();
  const documentPaths = files
    .filter((file) => sourcePathToSlug(file).length > 1)
    .map((file) => ({
      params: {
        slug: sourcePathToSlug(file).join("/"),
      },
      props: {
        kind: "document" as const,
      },
    }));
  const archivePaths = (await getArchivePaths()).map((slug) => ({
    params: {
      slug: slug.join("/"),
    },
    props: {
      kind: "archive" as const,
    },
  }));

  return [...documentPaths, ...archivePaths];
}

const slug = Astro.params.slug?.split("/").filter(Boolean) ?? [];
const { kind } = Astro.props as RouteProps;
const archive = kind === "archive" ? await getArchiveRecord(slug) : null;

if (kind === "archive" && !archive) {
  throw new Error(`Archive route missing for ${slug.join("/")}`);
}

const documentSourcePath = kind === "document" ? await resolveDocumentPath(slug) : null;
const document = documentSourcePath ? await readMirrorDocument(documentSourcePath) : null;
const title = archive?.title ?? document?.metadata.title ?? slug.join("/");
const currentHost = archive?.host ?? slug[0] ?? "";
const siteMeta = getSiteMeta(currentHost);
const breadcrumbs = getBreadcrumbsFromSlug(slug);
const docsNavigation = currentHost === "platform.claude.com" ? await getDocsNavigation(slug) : [];
const supportTopics = currentHost === "support.claude.com" ? await getSupportTopicGroups() : [];

const availableTranslations = new Set(document?.entries.flatMap((entry) => Object.keys(entry.translations)) ?? []);
const isBilingual = availableTranslations.size > 1;

const record =
  document && kind === "document"
    ? ({
        href: `/${slug.join("/")}/`,
        title,
        host: currentHost,
        slug,
        section:
          slug[0] === "platform.claude.com"
            ? "docs"
            : slug[0] === "support.claude.com"
              ? "articles"
              : slug[0] === "alignment.anthropic.com" || slug[0] === "red.anthropic.com"
                ? "blog"
                : slug[1] ?? document.metadata.section ?? "home",
        date: document.metadata.date ?? null,
        description: "",
        document,
        hasTranslations: isBilingual,
      } as const)
    : null;

const related = record ? await getRelatedDocuments(record) : [];
const archiveYearGroups = archive && archive.host === "www.anthropic.com" && archive.slug.length === 2 ? groupDocumentsByYear(archive.items) : [];
const resourceCollections = archive && archive.host === "claude.com" && archive.slug[1] === "resources" ? buildArchiveCollections(archive) : [];
const archiveFeature = archive ? archive.items[0] ?? null : null;
const archiveSecondary = archive ? archive.items.slice(1, 4) : [];
const claudeArchivePanels =
  archive && archive.host === "claude.com" && ["product", "solutions", "customers", "connectors", "plugins", "resources"].includes(archive.slug[1] ?? "")
    ? buildClaudeArchivePanels(archive)
    : [];

function groupDocumentsByYear(items: DocumentRecord[]) {
  const groups = new Map<string, DocumentRecord[]>();

  for (const item of items) {
    const year = item.date?.slice(0, 4) ?? "Undated";
    const current = groups.get(year) ?? [];
    current.push(item);
    groups.set(year, current);
  }

  return Array.from(groups.entries())
    .sort((left, right) => right[0].localeCompare(left[0]))
    .map(([year, yearItems]) => ({
      label: year,
      items: yearItems.sort((left, right) => (right.date ?? "").localeCompare(left.date ?? "") || left.title.localeCompare(right.title)),
    }));
}

function buildArchiveCollections(currentArchive: ArchiveRecord) {
  return currentArchive.children
    .map((child) => ({
      ...child,
      items: currentArchive.items
        .filter((item) => item.slug[currentArchive.slug.length] === child.href.split("/").filter(Boolean).at(-1))
        .slice(0, 10),
    }))
    .filter((child) => child.items.length > 0);
}

function buildClaudeArchivePanels(currentArchive: ArchiveRecord) {
  if (currentArchive.slug[1] === "resources") {
    return resourceCollections;
  }

  return currentArchive.children
    .map((child) => ({
      ...child,
      items: currentArchive.items
        .filter((item) => item.slug[currentArchive.slug.length] === child.href.split("/").filter(Boolean).at(-1))
        .slice(0, 6),
    }))
    .filter((child) => child.items.length > 0)
    .slice(0, 6);
}
---

<BaseLayout
  title={title}
  description={archive?.description ?? `${siteMeta.label}: ${title}`}
  sourceUrl={document?.metadata.source_url}
  defaultMode={isBilingual ? "bilingual" : "source-only"}
  currentHost={currentHost}
>
  {archive ? (
    <>
      <section class="article-header archive-header">
        <Breadcrumbs items={breadcrumbs} />
        <p class="eyebrow">{siteMeta.shortLabel}</p>
        <h1>{archive.title}</h1>
        <p class="hero-copy">{archive.description}</p>
        <p class="meta-line">
          <span>{archive.items.length} pages</span>
          <span>{siteMeta.label}</span>
          <span>mirror archive</span>
        </p>
      </section>

      <HostSectionNav host={archive.host} activeHref={archive.href} />

      <div class="content-frame">
        {archive.host === "platform.claude.com" ? <DocsSidebar groups={docsNavigation} activeHref={archive.href} /> : null}
        {archive.host === "support.claude.com" ? <SupportSidebar groups={supportTopics} activeHref={archive.href} /> : null}
        <section class="article-column">
          {archiveFeature && (archive.host === "www.anthropic.com" && archive.slug.length === 2) ? (
            <section class="feature-shell editorial-shell">
              <a class="feature-card feature-primary editorial-primary" href={archiveFeature.href}>
                <span class="feature-kicker">Featured</span>
                <strong>{archiveFeature.title}</strong>
                <span>{archiveFeature.date ?? archiveFeature.section}</span>
                {archiveFeature.description && <p>{archiveFeature.description}</p>}
              </a>
              <div class="feature-stack">
                {archiveSecondary.map((item) => (
                  <a class="feature-card feature-compact editorial-compact" href={item.href}>
                    <span class="feature-kicker">Latest</span>
                    <strong>{item.title}</strong>
                    <span>{item.date ?? item.section}</span>
                    {item.description && <p>{item.description}</p>}
                  </a>
                ))}
              </div>
            </section>
          ) : null}

          {archiveFeature && archive.host === "claude.com" && ["product", "solutions", "customers", "connectors", "plugins", "resources"].includes(archive.slug[1] ?? "") ? (
            <section class="feature-shell product-shell">
              <a class="feature-card feature-primary product-primary" href={archiveFeature.href}>
                <span class="feature-kicker">Highlighted</span>
                <strong>{archiveFeature.title}</strong>
                <span>{archiveFeature.date ?? `${archive.items.length} pages`}</span>
                {archiveFeature.description && <p>{archiveFeature.description}</p>}
              </a>
              <div class="feature-stack">
                {archiveSecondary.map((item) => (
                  <a class="feature-card feature-compact product-compact" href={item.href}>
                    <span class="feature-kicker">Explore</span>
                    <strong>{item.title}</strong>
                    <span>{item.date ?? item.section}</span>
                    {item.description && <p>{item.description}</p>}
                  </a>
                ))}
              </div>
            </section>
          ) : null}

          {archive.host === "claude.com" && archive.slug[1] === "resources" ? (
            <>
              {archive.children.length > 0 && <DirectoryList title="Collections" items={archive.children} />}
              <section class="section-grid">
                {resourceCollections.map((collection) => (
                  <SectionList title={collection.label} href={collection.href} items={collection.items.slice(0, 8)} />
                ))}
              </section>
            </>
          ) : archive.host === "claude.com" && ["product", "solutions", "customers", "connectors", "plugins"].includes(archive.slug[1] ?? "") ? (
            <>
              {archive.children.length > 0 && <DirectoryList title="Collections" items={archive.children} />}
              <section class="section-grid">
                {claudeArchivePanels.map((collection) => (
                  <SectionList title={collection.label} href={collection.href} items={collection.items.slice(0, 6)} />
                ))}
              </section>
            </>
          ) : archive.host === "www.anthropic.com" && archive.slug.length === 2 ? (
            <>
              <SectionList title="Recent" items={archive.items.slice(0, 12)} />
              <section class="section-grid">
                {archiveYearGroups.slice(0, 4).map((group) => (
                  <SectionList title={group.label} items={group.items.slice(0, 8)} />
                ))}
              </section>
            </>
          ) : archive.host === "support.claude.com" ? (
            supportTopics.map((group) => <SectionList title={group.label} items={group.items.slice(0, 10)} />)
          ) : (
            <>
              {archive.children.length > 0 && <DirectoryList title="Subsections" items={archive.children} />}
              <SectionList title={`Latest in ${prettifySegment(slug.at(-1) ?? archive.host)}`} items={archive.items.slice(0, 18)} />
            </>
          )}
        </section>
      </div>
    </>
  ) : record && document ? (
    <>
      <section class="article-header">
        <Breadcrumbs items={breadcrumbs} />
        <p class="eyebrow">{prettifySegment(record.section)}</p>
        <h1>{title}</h1>
        <p class="meta-line">
          <span>{document.metadata.date ?? "undated"}</span>
          <span>{siteMeta.shortLabel}</span>
          <span>{isBilingual ? "bilingual" : "source only"}</span>
        </p>
      </section>

      <HostSectionNav host={record.host} activeHref={record.href} />

      {isBilingual ? <LanguageToggle /> : <p class="status-note">Translation pending. This page is currently rendered from the original crawler markdown.</p>}

      <div class="content-frame">
        {record.host === "platform.claude.com" ? <DocsSidebar groups={docsNavigation} activeHref={record.href} /> : null}
        {record.host === "support.claude.com" ? <SupportSidebar groups={supportTopics} activeHref={record.href} /> : null}
        <section class="article-column">
          <section class="article-body">
            {document.entries.map((entry) => (
              <BilingualBlock
                paraId={entry.id}
                en={entry.translations.en}
                zhHant={entry.translations["zh-Hant"]}
                ja={entry.translations.ja}
              />
            ))}
          </section>

          {related.length > 0 && <SectionList title="More in this section" items={related.slice(0, 8)} />}
        </section>
      </div>
    </>
  ) : null}
</BaseLayout>
