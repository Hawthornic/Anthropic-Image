---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BilingualBlock from "../../components/BilingualBlock.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import HostSectionNav from "../../components/HostSectionNav.astro";
import SectionList from "../../components/SectionList.astro";
import SupportSidebar from "../../components/SupportSidebar.astro";
import { getDocsGroups, getDocsNavigation, getHostSections, getHosts, getSiteMeta, getSupportTopicGroups } from "../../lib/catalog";
import { readMirrorDocument, resolveDocumentPath } from "../../lib/content";

export async function getStaticPaths() {
  const hosts = await getHosts();
  return hosts.map(({ host }) => ({
    params: { host },
  }));
}

const host = Astro.params.host ?? "";
const meta = getSiteMeta(host);
const sections = await getHostSections(host);
const homeDocument = await loadHomeDocument(host);
const docsGroups = host === "platform.claude.com" ? await getDocsGroups() : [];
const docsNavigation = host === "platform.claude.com" ? await getDocsNavigation([host, "docs", "en"]) : [];
const supportTopics = host === "support.claude.com" ? await getSupportTopicGroups() : [];
const sectionMap = new Map(sections.map((section) => [section.section, section]));
const claudeFeatureSections = ["product", "solutions", "customers", "connectors", "plugins", "resources", "blog"]
  .map((section) => sectionMap.get(section))
  .filter(Boolean);

async function loadHomeDocument(value: string) {
  try {
    return await readMirrorDocument(await resolveDocumentPath([value]));
  } catch {
    return null;
  }
}
---

<BaseLayout title={meta.label} description={meta.description} currentHost={host}>
  <section class="hero compact-hero">
    <p class="eyebrow">{meta.shortLabel}</p>
    <h1>{meta.label}</h1>
    <p class="hero-copy">{meta.description}</p>
  </section>

  <HostSectionNav host={host} activeHref={`/${host}/`} />

  {host === "platform.claude.com" ? (
    <div class="content-frame">
      <DocsSidebar groups={docsNavigation} activeHref="/platform.claude.com/docs/en/" />
      <section class="article-column">
        <section class="section-panel">
          <div class="section-heading">
            <h2>Docs Areas</h2>
            <span>{docsGroups.length}</span>
          </div>
          <div class="section-list compact">
            {docsGroups.map((group) => (
              <a class="section-item" href={`/${group.slug}/`}>
                <strong>{group.label}</strong>
                <span>{group.items.length} pages</span>
                <p>{group.items[0]?.description ?? "Browse the mirrored documentation area."}</p>
              </a>
            ))}
          </div>
        </section>

        <section class="section-grid">
          {sections.map((section) => (
            <SectionList title={section.label} href={section.href} items={section.items.slice(0, 18)} />
          ))}
        </section>
      </section>
    </div>
  ) : host === "support.claude.com" ? (
    <div class="content-frame">
      <SupportSidebar groups={supportTopics} activeHref="/support.claude.com/en/articles/" />
      <section class="article-column">
        <section class="section-panel support-landing-note">
          <div class="section-heading">
            <h2>Help Center</h2>
            <span>{supportTopics.length} topics</span>
          </div>
          <p>
            Browse the mirrored Claude help center by topic instead of scanning a single long article feed. This keeps
            account, billing, app, API, and enterprise guidance closer to how a real support center is used.
          </p>
        </section>

        <section class="section-grid">
          {supportTopics.map((group) => (
            <SectionList title={group.label} items={group.items.slice(0, 10)} />
          ))}
        </section>
      </section>
    </div>
  ) : host === "claude.com" ? (
    <>
      <section class="section-panel product-landing-panel">
        <div class="section-heading">
          <h2>Explore Claude</h2>
          <span>{claudeFeatureSections.length} sections</span>
        </div>
        <div class="section-list compact collection-grid">
          {claudeFeatureSections.map((section) => (
            <a class="section-item collection-card" href={section?.href}>
              <strong>{section?.label}</strong>
              <span>{section?.items.length} pages</span>
              <p>{section?.items[0]?.description ?? `Browse the mirrored ${section?.label.toLowerCase()} pages.`}</p>
            </a>
          ))}
        </div>
      </section>

      {homeDocument ? (
        <section class="section-panel">
          <div class="section-heading">
            <h2>Home Page</h2>
          </div>
          <div class="article-body">
            {homeDocument.entries.slice(0, 4).map((entry) => (
              <BilingualBlock
                paraId={entry.id}
                en={entry.translations.en}
                zhHant={entry.translations["zh-Hant"]}
                ja={entry.translations.ja}
              />
            ))}
          </div>
        </section>
      ) : null}

      <section class="section-grid">
        {["product", "customers", "connectors", "blog"].map((section) => sectionMap.get(section)).filter(Boolean).map((section) => (
          <SectionList title={section?.label ?? ""} href={section?.href} items={section?.items.slice(0, 12) ?? []} />
        ))}
      </section>
    </>
  ) : homeDocument ? (
    <section class="section-panel">
      <div class="section-heading">
        <h2>Home Page</h2>
      </div>
      <div class="article-body">
        {homeDocument.entries.slice(0, 6).map((entry) => (
          <BilingualBlock
            paraId={entry.id}
            en={entry.translations.en}
            zhHant={entry.translations["zh-Hant"]}
            ja={entry.translations.ja}
          />
        ))}
      </div>
    </section>
  ) : null}

  {host !== "platform.claude.com" && host !== "support.claude.com" && host !== "claude.com" ? (
    <section class="section-grid">
      {sections.map((section) => (
        <SectionList title={section.label} href={section.href} items={section.items.slice(0, 24)} />
      ))}
    </section>
  ) : null}
</BaseLayout>
